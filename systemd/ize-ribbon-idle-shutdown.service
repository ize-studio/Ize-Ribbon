[Unit]
Description=Ize Ribbon idle shutdown watcher
After=multi-user.target

[Service]
Type=simple
User=ize
WorkingDirectory=/home/ize/ize-ribbon
Environment=PYTHONUNBUFFERED=1
RuntimeDirectory=ize-ribbon
RuntimeDirectoryMode=0775
ExecStart=/usr/bin/python3 /home/ize/ize-ribbon/idle_shutdown.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
